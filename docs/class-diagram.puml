@startuml
skinparam linetype ortho
skinparam packageStyle frame

package "com.iol.crawler.model" {
    class URL {
        + originalString: String
        + domain: String
        + depth: Int
        + metadata: Map<String, String>
    }

    class HTMLContent {
        + rawBody: String
        + statusCode: Int
        + headers: Map<String, String>
        + fetchedAt: Long
    }
}

package "com.iol.crawler.protocol" {
    interface IHTMLFetcher {
        + fetch(url: URL): Result<HTMLContent>
    }

    interface IHTMLParser {
        + parse(content: HTMLContent): List<URL>
    }

    interface IURLFrontier {
        + push(url: URL)
        + next(): URL?
        + isEmpty(): Boolean
    }

    interface IDuplicateFilter {
        + isDuplicate(content: HTMLContent): Boolean
        + markProcessed(url: URL)
    }

    interface IPolitenessGovernor {
        + acquirePermission(domain: String)
        + releasePermission(domain: String)
    }

    interface IMessageDispatcher {
        + dispatch(url: URL)
    }
}

package "com.iol.crawler.engine" {
    class CrawlerOrchestrator {
        - frontier: IURLFrontier
        - dispatcher: IMessageDispatcher
        - parser: IHTMLParser
        + start(seeds: List<URL>)
        + shutdown()
    }

    class DownloadWorker {
        - fetcher: IHTMLFetcher
        - governor: IPolitenessGovernor
        - filter: IDuplicateFilter
        + process(url: URL)
    }
}

'' Relationships
CrawlerOrchestrator --> IURLFrontier
CrawlerOrchestrator --> IMessageDispatcher
CrawlerOrchestrator --> IHTMLParser

DownloadWorker --> IHTMLFetcher
DownloadWorker --> IPolitenessGovernor
DownloadWorker --> IDuplicateFilter

IMessageDispatcher ..> DownloadWorker : "Triggers"
IHTMLParser ..> IURLFrontier : "Feeds new links"
DownloadWorker ..> IHTMLParser : "Passes content"

@enduml
